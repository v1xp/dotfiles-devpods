{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-ralph-loop",
    ".opencode/plugins/graphify.js"
  ],
  "provider": {},
  "model": "",
  "small_model": "",
  "permission": {
    "edit": "ask",
    "write": "ask",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "gh *": "allow",
      "docker *": "allow",
      "docker compose *": "allow",
      "uv *": "allow",
      "pip *": "allow",
      "python *": "allow",
      "graphify *": "allow",
      "nvim *": "allow",
      "tmux *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "wc *": "allow",
      "mkdir *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "rm -rf *": "ask",
      "rm *": "ask",
      "sudo *": "ask",
      "curl *": "allow",
      "wget *": "allow",
      "tar *": "allow",
      "unzip *": "allow"
    },
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "task": "allow",
    "todowrite": "allow"
  }
}
